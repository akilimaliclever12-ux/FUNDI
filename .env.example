# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER ONLY — never expose

# ---- Photo storage ----
# Photos are stored in Supabase Storage (public bucket "worker-photos").
# No third-party image host required. Create the bucket with:
#   node --env-file=.env.local scripts/setup-storage.mjs

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
REVALIDATE_SECRET=change-me-to-a-long-random-string

# ---- Email (Resend) — optional for MVP ----
RESEND_API_KEY=

# ---- Analytics (public) — optional ----
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
